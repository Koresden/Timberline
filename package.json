{
  "name": "timberline",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Timberline — a mobile-first, offline-capable tree-felling planning assistant. Planning aid, not authorization.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:offline": "playwright test --config playwright.offline.config.ts",
    "test:e2e:swupdate": "playwright test --config playwright.swupdate.config.ts",
    "build:native": "TIMBERLINE_NATIVE=1 tsc -b && TIMBERLINE_NATIVE=1 vite build",
    "ios:sync": "npm run build:native && cap sync ios",
    "ios:open": "cap open ios",
    "ios:run": "npm run ios:sync && cap run ios"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.0"
  }
}
